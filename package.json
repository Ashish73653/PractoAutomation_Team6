{
  "name": "practoautomation_team6",
  "version": "1.0.0",
  "description": "This document contains end-to-end automation and manual testing scenarios for major modules of the Practo application. The scenarios cover user registration, login, doctor consultation, lab tests, medicine ordering, health feed, footer validation, and help/support functionalities.",
  "main": "index.js",
  "scripts": {
    "save-auth": "node tests/util/saveAuth.js",
    "test": "cucumber-js tests/Features --require tests/Hooks/*.js --require tests/Steps/*.js",
    "test:debug:win": "powershell -Command \"$env:PWDEBUG=1; npx cucumber-js tests/Features\"",
    "report:allure": "npx allure generate allure-results --clean -o allure-report",
    "open:allure": "npx allure open allure-report",
    "report": "npm run report:allure && npm run open:allure"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ashish73653/PractoAutomation_Team6.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Ashish73653/PractoAutomation_Team6/issues"
  },
  "homepage": "https://github.com/Ashish73653/PractoAutomation_Team6#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-cucumberjs": "^3.8.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.8.0",
    "playwright-bdd": "^8.5.0"
  }
}
